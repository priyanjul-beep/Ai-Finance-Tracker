# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development          # development | production
APP_NAME="AI Finance Tracker"
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgres://user:password@ep-xxx.ap-south-1.aws.neon.tech/finance_db?sslmode=require

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ─── SMTP Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@yourapp.com
FROM_NAME="AI Finance Tracker"

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_TYPE=local                # local | cloudinary
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760            # 10 MB in bytes

# ─── Cloudinary (optional, only if STORAGE_TYPE=cloudinary) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase (optional, for push notifications) ──────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_OCR=false
ENABLE_VOICE=false
ENABLE_AI_CATEGORIZATION=true
ENABLE_DUPLICATE_DETECTION=true
ENABLE_RECURRING_DETECTION=true
