!.env.example

# ─── Firebase ─────────────────────────────────────────────────────────────────
firebase.json
.firebaserc
firebase-debug.log

# ─── Go ───────────────────────────────────────────────────────────────────────
# Compiled binaries and executables
backend/bin/
backend/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Coverage output
*.out
coverage.html

# Go vendor directory (we rely on go modules)
vendor/

# Go build cache (managed by Go toolchain, not needed in repo)
# go.sum IS committed – it locks dependency hashes

# Air live-reload tmp
backend/tmp/

# ─── Node / Next.js / Frontend ────────────────────────────────────────────────
node_modules/
.npm/
.pnp
.pnp.js

# Next.js build output
frontend/.next/
frontend/out/

# Nuxt / Vite
.nuxt/
.output/
dist/

# Turbo
.turbo/

# SWC / Babel caches
.swc/

# TypeScript build cache
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

